add <Basic.axo>
int num[] = «0,3,5,7,3»
char saludo[] = «hola»

Com miComplejo = 2.1i
Int edad = 25
Dec pi = 3.1416
Bool activo = true
Punt miCopia = *edad
pkg algo = {
  char letra
  Dec gd
  func saludar = () :[]char{
  return «Hola desde variable»
}
func suma = (int a, int b):int {
int sum
sum = a + b
 return sum
}
}
any variableComodin = «adios»

func hola2 = (){
printf(«Hola desde funcion globql\n»)
}

func main = (){
algo p1
p1.letra = 'a'
 printf(«%s\n»,saludo)
 printf(«%s\n», p1.saludar())
 printf(«%c\n», p1.letra)
 printf(«%s\n», (char*)variableComodin)
 for (int i = 0; i < 5; i++){
 printf(«%d\n», num[i])
 }
 hola2()
 printf(«%.1f %.1fi\n», creal(miComplejo), cimag(miComplejo))
 printf(«%p\n», miCopia)
 printf(«%d\n», p1.suma(2,4))
  Stop(system)

}
main()

